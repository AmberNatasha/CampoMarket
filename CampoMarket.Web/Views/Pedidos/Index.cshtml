@model IEnumerable<CampoMarket.Web.Models.Pedido>
@{
    ViewData["Title"] = "Mis pedidos";
}

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <h1 class="section-title mb-4">Mis pedidos</h1>
        <div class="cm-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>Numero</th><th>Fecha</th><th>Total</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var pedido in Model)
                        {
                            <tr>
                                <td>@pedido.Numero</td>
                                <td>@pedido.FechaUtc.ToLocalTime().ToString("g")</td>
                                <td>$@pedido.Total.ToString("0.00")</td>
                                <td><span class="badge status-@pedido.Estado.ToLowerInvariant()">@pedido.Estado</span></td>
                                <td><a class="btn btn-outline-primary" asp-controller="Pedidos" asp-action="Detalle" asp-route-id="@pedido.Id">Detalle</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
