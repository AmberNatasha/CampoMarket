@model CampoMarket.Web.Models.ProductoFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Nuevo producto" : "Editar producto";
    var tieneCategorias = Model.Categorias.Any();
}

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="cm-card">
            <h1 class="h3 mb-4">@ViewData["Title"]</h1>
            @if (!tieneCategorias)
            {
                <div class="alert alert-danger">
                    No hay categorias activas. Crea una categoria antes de guardar productos.
                    <a asp-controller="Admin" asp-action="NuevaCategoria">Crear categoria</a>
                </div>
            }
            <form method="post" asp-controller="Admin" asp-action="GuardarProducto" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImagenUrl" />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Nombre"></label>
                        <input class="form-control" asp-for="Nombre" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" asp-for="Precio"></label>
                        <input class="form-control" asp-for="Precio" />
                        <div class="form-text">Monto en colones.</div>
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" asp-for="CategoriaId">Categoria</label>
                        <select class="form-select" asp-for="CategoriaId" disabled="@(!tieneCategorias)">
                            @foreach (var categoria in Model.Categorias)
                            {
                                <option value="@categoria.Id">@categoria.Nombre</option>
                            }
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label" asp-for="Descripcion"></label>
                        <textarea class="form-control" asp-for="Descripcion"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" asp-for="Stock"></label>
                        <input class="form-control" asp-for="Stock" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" asp-for="StockMinimo"></label>
                        <input class="form-control" asp-for="StockMinimo" />
                        <span asp-validation-for="StockMinimo" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" asp-for="ImagenArchivo">Imagen del producto</label>
                        <input class="form-control" asp-for="ImagenArchivo" type="file" accept="image/*" />
                        <span asp-validation-for="ImagenArchivo" class="text-danger"></span>
                        @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
                        {
                            <div class="form-text">Imagen actual: @Model.ImagenUrl</div>
                        }
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Activo" />
                            <label class="form-check-label" asp-for="Activo">Producto activo y visible en Catalogo</label>
                        </div>
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button class="btn btn-primary" type="submit" disabled="@(!tieneCategorias)">Guardar</button>
                    <a class="btn btn-outline-primary" asp-controller="Admin" asp-action="Productos">Volver</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
