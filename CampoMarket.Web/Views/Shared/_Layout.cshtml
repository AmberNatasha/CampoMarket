<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Campo Market, supermercado organico online express." />
    <title>@ViewData["Title"] - Campo Market</title>
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@700&family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark cm-navbar">
            <div class="container px-4 px-lg-5">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img class="brand-logo" src="~/Images/Logo.png" alt="Campo Market" />
                    <span>Campo Market</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="Abrir navegacion">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavigation">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Catalogo" asp-action="Index">Catálogo</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Admin</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Clientes">Clientes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Productos">Inventario</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Categorias">Categorias</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Reportes">Reportes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Auditoria">Auditoria</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Carrito" asp-action="Index">Carrito</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Pedidos" asp-action="Index">Mis pedidos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Cuenta" asp-action="Direcciones">Direcciones</a></li>
                            }
                            <li class="nav-item"><a class="nav-link" asp-controller="Cuenta" asp-action="Perfil">Perfil</a></li>
                            <li class="nav-item ms-lg-3">
                                <form method="post" asp-controller="Cuenta" asp-action="Logout">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-warning" type="submit">Salir</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-3"><a class="btn btn-outline-light" asp-controller="Cuenta" asp-action="Login">Iniciar sesion</a></li>
                            <li class="nav-item ms-lg-2"><a class="btn btn-success" asp-controller="Cuenta" asp-action="Registro">Registrarse</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (TempData["Flash"] is string flash)
    {
        var type = TempData["FlashType"] as string ?? "success";
        var icon = type == "danger" ? "bi-exclamation-circle-fill" : "bi-check-circle-fill";
        <div class="cm-toast-container" aria-live="polite" aria-atomic="true">
            <div class="toast cm-toast cm-toast-@type" role="status" data-bs-autohide="true" data-bs-delay="4500">
                <div class="toast-body">
                    <i class="bi @icon cm-toast-icon" aria-hidden="true"></i>
                    <span>@flash</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="toast" aria-label="Cerrar mensaje"></button>
                </div>
            </div>
        </div>
    }

    <main role="main">
        @RenderBody()
    </main>

    <footer class="cm-footer py-4">
        <div class="container px-4 px-lg-5">
            <div class="row align-items-center justify-content-between gy-3">
                <div class="col-md-auto">
                    <div class="small">Copyright &copy; Campo Market 2026</div>
                </div>
                <div class="col-md-auto">
                    <a asp-controller="Home" asp-action="Privacy">Privacidad</a>
                    <span class="mx-2">·</span>
                    <a asp-controller="Home" asp-action="Contact">Contacto</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
