@model CampoMarket.Web.Models.RegistroViewModel
@{
    ViewData["Title"] = "Registro";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Compra fresco y facil</span>
        <h1>Crear cuenta</h1>
        <p>Crea tu cuenta para comprar fresco, organico y rapido.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="cm-card">
                    <h2 class="h3 text-center mb-4">Registro en Campo Market</h2>
                    <form method="post" asp-controller="Cuenta" asp-action="Registro">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" asp-for="Nombre"></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ingrese su nombre" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" asp-for="Correo"></label>
                                <input asp-for="Correo" class="form-control" placeholder="correo@ejemplo.com" />
                                <span asp-validation-for="Correo" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" asp-for="Telefono"></label>
                                <input asp-for="Telefono" class="form-control" placeholder="88888888" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label" asp-for="Password">contraseña</label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="Minimo 8 caracteres" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="Direccion"></label>
                            <input asp-for="Direccion" class="form-control" placeholder="Direccion de entrega" />
                        </div>
                        <button type="submit" class="btn btn-success btn-lg w-100">Registrarse</button>
                    </form>
                    <hr />
                    <div class="text-center d-grid">
                        <a class="btn btn-outline-success" asp-controller="Cuenta" asp-action="Login">Ya tengo cuenta</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
