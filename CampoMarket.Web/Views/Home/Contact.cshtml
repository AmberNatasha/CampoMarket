@model CampoMarket.Web.Models.ContactoViewModel
@{
    ViewData["Title"] = "Contacto";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Estamos cerca</span>
        <h1>Contáctanos</h1>
        <p>Estamos listos para ayudarte con pedidos, entregas y productos frescos.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="cm-card">
                    <form method="post" asp-controller="Home" asp-action="Contact">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <div class="form-floating">
                                <input class="form-control" asp-for="Nombre" placeholder="Nombre completo" />
                                <label asp-for="Nombre"></label>
                            </div>
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <div class="form-floating">
                                <input class="form-control" asp-for="Correo" type="email" placeholder="correo@ejemplo.com" />
                                <label asp-for="Correo"></label>
                            </div>
                            <span asp-validation-for="Correo" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <div class="form-floating">
                                <input class="form-control" asp-for="Telefono" type="tel" placeholder="8888-8888" />
                                <label asp-for="Telefono"></label>
                            </div>
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <div class="form-floating">
                                <textarea class="form-control" asp-for="Mensaje" placeholder="Mensaje" style="height: 10rem"></textarea>
                                <label asp-for="Mensaje"></label>
                            </div>
                            <span asp-validation-for="Mensaje" class="text-danger"></span>
                        </div>
                        <button class="btn btn-primary btn-lg w-100" type="submit">Enviar</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="row g-4">
                    <div class="col-sm-6 col-lg-12">
                        <div class="cm-card h-100">
                            <i class="bi bi-chat-dots cm-icon"></i>
                            <h3>Llamanos al 8888-1234</h3>
                            <p>Consulta disponibilidad, horarios y estado de tu entrega express.</p>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-12">
                        <div class="cm-card h-100">
                            <i class="bi bi-geo-alt-fill cm-icon"></i>
                            <h3>Ubicación</h3>
                            <p>Nos ubicamos en San José con entregas en toda la GAM, consulta por disponibilidad en tu zona.</p>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-12">
                        <div class="cm-card h-100">
                            <i class="bi bi-telephone cm-icon"></i>
                            <h3>Atención cercana</h3>
                            <p>Resolvemos dudas sobre productos, pagos y zonas de entrega.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
