@{
    ViewData["Title"] = "Nosotros";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Frescura y calidad desde 2026</span>
        <h1>Acerca de Campo Market</h1>
        <p>Somos un supermercado orgánico online express enfocado en frescura, calidad y compras simples desde casa.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <h2 class="section-title">Nuestro objetivo</h2>
                <p class="lead">Acercar productos orgánicos, frutas, verduras y básicos saludables con una experiencia rápida, clara y confiable.</p>
                <p>Campo Market combina selección fresca, atención cercana y entregas express para que tu cocina esté siempre lista.</p>
            </div>
            <div class="col-lg-6">
                <div class="cm-card">
                    <h3>Lo que cuidamos</h3>
                    <ul class="cm-list">
                        <li>Productos frescos con apariencia y sabor natural.</li>
                        <li>Compras simples, sin filas y desde cualquier dispositivo.</li>
                        <li>Empaque cuidadoso para conservar calidad en la entrega.</li>
                        <li>Servicio cercano, familiar y fácil de entender.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
