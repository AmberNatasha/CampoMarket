@{
    ViewData["Title"] = "Iniciar sesión";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Tu cuenta Campo Market</span>
        <h1>Bienvenido</h1>
        <p>Ingresa para revisar tus pedidos orgánicos y entregas express.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="cm-card">
                    <h2 class="h3 text-center mb-4">Iniciar sesión</h2>

                    @if (!string.IsNullOrWhiteSpace(ViewBag.Mensaje as string))
                    {
                        <div class="alert alert-@ViewBag.TipoMensaje">@ViewBag.Mensaje</div>
                    }

                    <form method="post" asp-controller="Home" asp-action="Login">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" for="usuario">Usuario</label>
                            <input id="usuario" type="text" name="usuario" class="form-control" placeholder="admin" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="password">Contraseña</label>
                            <input id="password" type="password" name="password" class="form-control" placeholder="1234" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Ingresar</button>
                    </form>

                    <hr />
                    <div class="text-center">
                        <a asp-controller="Home" asp-action="Recuperar">¿Olvidó su contraseña?</a>
                    </div>
                    <div class="text-center mt-3">
                        ¿No tiene cuenta? <a asp-controller="Home" asp-action="Registro">Registrarse</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
