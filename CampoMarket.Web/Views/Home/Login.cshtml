@{
    ViewData["Title"] = "Iniciar sesion";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Tu cuenta Campo Market</span>
        <h1>Bienvenido</h1>
        <p>Ingresa para comprar, revisar pedidos o administrar el inventario.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="cm-card">
                    <h2 class="h3 text-center mb-4">Iniciar sesion</h2>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Mensaje as string))
                    {
                        <div class="alert alert-@ViewBag.TipoMensaje">@ViewBag.Mensaje</div>
                    }

                    <form method="post" asp-controller="Cuenta" asp-action="Login">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" for="correo">Correo</label>
                            <input id="correo" type="email" name="correo" class="form-control" placeholder="cliente@campomarket.test" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="password">Contrasena</label>
                            <input id="password" type="password" name="password" class="form-control" placeholder="Cliente123!" required />
                        </div>
                        <button type="submit" class="btn btn-success btn-lg w-100">Iniciar sesion</button>
                    </form>

                    <div class="mt-3 small text-muted">
                        <div>Cliente demo: cliente@campomarket.test / Cliente123!</div>
                        <div>Admin demo: admin@campomarket.test / Admin123!</div>
                    </div>
                    <hr />
                    <div class="text-center">
                        <a asp-controller="Cuenta" asp-action="Recuperar">Olvide mi contrasena</a>
                    </div>
                    <div class="text-center mt-3 d-grid">
                        <a class="btn btn-outline-success" asp-controller="Cuenta" asp-action="Registro">Crear cuenta</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
