@{
    ViewData["Title"] = "Recuperar contraseña";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Acceso a tu cuenta</span>
        <h1>Recuperar contraseña</h1>
        <p>Ingresa tu correo para recuperar el acceso a tus compras.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="cm-card text-center">
                    <i class="bi bi-envelope-lock cm-icon cm-icon-large"></i>
                    <h2 class="h3 mt-3">¿Olvidó su contraseña?</h2>
                    <p class="text-muted">Escriba su correo electrónico y le enviaremos un enlace para restablecer su contraseña.</p>
                    <form>
                        <div class="mb-4 text-start">
                            <label class="form-label" for="correo-recuperar">Correo electrónico</label>
                            <input id="correo-recuperar" type="email" class="form-control" placeholder="correo@ejemplo.com" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">Enviar enlace</button>
                    </form>
                    <hr />
                    <a asp-controller="Home" asp-action="Login">Volver al inicio de sesión</a>
                </div>
            </div>
        </div>
    </div>
</section>
