@model CampoMarket.Web.Models.RecuperarPasswordViewModel
@{
    ViewData["Title"] = "Recuperar contraseña";
}

<section class="cm-page-header">
    <div class="container px-4 px-lg-5">
        <span class="cm-kicker">Seguridad de cuenta</span>
        <h1>Recuperar contraseña</h1>
        <p>Genera un enlace temporal valido por una hora.</p>
    </div>
</section>

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="cm-card">
                    @if (ViewBag.Mensaje is string mensaje)
                    {
                        <div class="alert alert-success">@mensaje</div>
                    }
                    @if (ViewBag.Token is string token)
                    {
                        <div class="alert alert-info">
                            Prototipo: <a asp-controller="Cuenta" asp-action="Restablecer" asp-route-token="@token">abrir enlace de restablecimiento</a>
                        </div>
                    }
                    <form method="post" asp-controller="Cuenta" asp-action="Recuperar">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label" asp-for="Correo"></label>
                            <input class="form-control" asp-for="Correo" placeholder="correo@ejemplo.com" />
                            <span asp-validation-for="Correo" class="text-danger"></span>
                        </div>
                        <button class="btn btn-primary w-100" type="submit">Generar enlace</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
