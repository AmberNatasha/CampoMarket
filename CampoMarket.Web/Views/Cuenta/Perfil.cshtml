@model CampoMarket.Web.Models.PerfilViewModel
@{
    ViewData["Title"] = "Perfil";
}

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cm-card">
                    <h1 class="h3 mb-4">Mi perfil</h1>
                    <form method="post" asp-controller="Cuenta" asp-action="Perfil">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="Nombre"></label>
                            <input class="form-control" asp-for="Nombre" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="Telefono"></label>
                            <input class="form-control" asp-for="Telefono" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="Direccion"></label>
                            <input class="form-control" asp-for="Direccion" />
                        </div>
                        <button class="btn btn-primary" type="submit">Guardar cambios</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="cm-card">
                    <h2 class="h5">Seguridad</h2>
                    <p class="text-muted">Actualiza tu contrasena cuando lo necesites.</p>
                    <a class="btn btn-outline-primary w-100" asp-controller="Cuenta" asp-action="CambiarPassword">Cambiar contrasena</a>
                    @if (User.IsInRole("Cliente"))
                    {
                        <a class="btn btn-outline-primary w-100 mt-2" asp-controller="Cuenta" asp-action="Direcciones">Mis direcciones</a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
