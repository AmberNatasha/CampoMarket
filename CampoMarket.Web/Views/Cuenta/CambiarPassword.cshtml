@model CampoMarket.Web.Models.CambiarPasswordViewModel
@{
    ViewData["Title"] = "Cambiar contraseña";
}

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="cm-card">
                    <h1 class="h3 mb-4">Cambiar contraseña</h1>
                    <form method="post" asp-controller="Cuenta" asp-action="CambiarPassword">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" asp-for="PasswordActual">contraseña actual</label>
                            <input class="form-control" asp-for="PasswordActual" type="password" />
                            <span asp-validation-for="PasswordActual" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="PasswordNuevo">Nueva contraseña</label>
                            <input class="form-control" asp-for="PasswordNuevo" type="password" />
                            <span asp-validation-for="PasswordNuevo" class="text-danger"></span>
                        </div>
                        <button class="btn btn-primary" type="submit">Actualizar</button>
                        <a class="btn btn-outline-primary" asp-controller="Cuenta" asp-action="Perfil">Volver</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
