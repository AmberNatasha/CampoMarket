@model CampoMarket.Web.Models.DireccionFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Nueva direccion" : "Editar direccion";
}

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="cm-card">
            <h1 class="h3 mb-4">@ViewData["Title"]</h1>
            <form method="post" asp-controller="Cuenta" asp-action="GuardarDireccion">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Alias"></label>
                        <input class="form-control" asp-for="Alias" placeholder="Casa, trabajo, etc." />
                        <span asp-validation-for="Alias" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Provincia"></label>
                        <input class="form-control" asp-for="Provincia" />
                        <span asp-validation-for="Provincia" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Canton"></label>
                        <input class="form-control" asp-for="Canton" />
                        <span asp-validation-for="Canton" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Distrito"></label>
                        <input class="form-control" asp-for="Distrito" />
                        <span asp-validation-for="Distrito" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label" asp-for="SenasExactas">Senas exactas</label>
                        <textarea class="form-control" asp-for="SenasExactas"></textarea>
                        <span asp-validation-for="SenasExactas" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Predeterminada" />
                            <label class="form-check-label" asp-for="Predeterminada">Usar como predeterminada</label>
                        </div>
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Guardar</button>
                    <a class="btn btn-outline-primary" asp-controller="Cuenta" asp-action="Direcciones">Volver</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
