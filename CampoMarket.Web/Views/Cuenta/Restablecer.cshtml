@model CampoMarket.Web.Models.RestablecerPasswordViewModel
@{
    ViewData["Title"] = "Restablecer contrasena";
}

<section class="py-5">
    <div class="container px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="cm-card">
                    <h1 class="h3 mb-4">Restablecer contrasena</h1>
                    <form method="post" asp-controller="Cuenta" asp-action="Restablecer">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Token" />
                        <div class="mb-4">
                            <label class="form-label" asp-for="PasswordNuevo">Nueva contrasena</label>
                            <input class="form-control" asp-for="PasswordNuevo" type="password" />
                            <span asp-validation-for="PasswordNuevo" class="text-danger"></span>
                        </div>
                        <button class="btn btn-primary w-100" type="submit">Guardar nueva contrasena</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
